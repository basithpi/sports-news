# Optional: add free API keys here if you extend the fetchers.
# The default pipeline works with free public RSS feeds and Edge TTS.

SHORTS_PER_RUN=10
OUTPUT_DIR=output
EDGE_TTS_VOICE=en-US-GuyNeural

# YouTube upload automation. Create this OAuth desktop-client JSON in Google Cloud.
YOUTUBE_CLIENT_SECRETS=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_SCHEDULE_DELAY_MINUTES=20
YOUTUBE_SCHEDULE_INTERVAL_MINUTES=20
PIPELINE_STATE_FILE=.sports_shorts_state.json
DELETE_OLD_RUNS_AFTER_UPLOAD=true
